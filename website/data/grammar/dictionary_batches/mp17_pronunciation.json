    "word": "woulda",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'would have'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "I woulda come, but I was sick.",
        "hi": "मैं आता, लेकिन मैं बीमार था।"
      }
    ],
    "notes": "Often used in third conditional sentences."
  },
  {
    "id": "mp17-22",
    "word": "musta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'must have'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B2",
    "examples": [
      {
        "en": "He musta left early.",
        "hi": "वह शायद जल्दी निकल गया होगा।"
      }
    ],
    "notes": "Used for past deductions."
  },
  {
    "id": "mp17-23",
    "word": "mighta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'might have'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B2",
    "examples": [
      {
        "en": "I mighta made a mistake.",
        "hi": "मुझसे शायद कोई गलती हो गई होगी।"
      }
    ],
    "notes": "Expresses past possibility."
  },
  {
    "id": "mp17-24",
    "word": "oughta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'ought to'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B2",
    "examples": [
      {
        "en": "You oughta apologize.",
        "hi": "तुम्हें माफ़ी माँगनी चाहिए।"
      }
    ],
    "notes": "Flap T makes 'ought to' sound like 'oudda'."
  },
  {
    "id": "mp17-25",
    "word": "haffta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken pronunciation of 'have to'.",
    "usageContext": "connected speech",
    "cefrLevel": "A2",
    "examples": [
      {
        "en": "I haffta go to work.",
        "hi": "मुझे काम पर जाना होगा।"
      }
    ],
    "notes": "The 'v' in 'have' assimilates to a 'f' sound before the unvoiced 't'."
  },
  {
    "id": "mp17-26",
    "word": "hasta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken pronunciation of 'has to'.",
    "usageContext": "connected speech",
    "cefrLevel": "A2",
    "examples": [
      {
        "en": "She hasta finish her homework.",
        "hi": "उसे अपना होमवर्क खत्म करना होगा।"
      }
    ],
    "notes": "The 'z' sound in 'has' becomes an 's' sound before 'to'."
  },
  {
