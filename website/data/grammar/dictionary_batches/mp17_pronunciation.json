[
  {
    "id": "mp17-1",
    "word": "gonna",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'going to'. Used for future plans or intentions.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A1",
    "examples": [
      {
        "en": "I'm gonna be late for the meeting.",
        "hi": "मुझे मीटिंग के लिए देर होने वाली है।"
      }
    ],
    "notes": "Native reduction. Never used in formal writing."
  },
  {
    "id": "mp17-2",
    "word": "wanna",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'want to' or 'want a'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A1",
    "examples": [
      {
        "en": "Do you wanna grab some coffee?",
        "hi": "क्या तुम कॉफ़ी पीना चाहते हो?"
      }
    ],
    "notes": "Very common in fast native speech."
  },
  {
    "id": "mp17-3",
    "word": "gotta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'have got to' or 'got to', meaning 'have to' or 'must'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A2",
    "examples": [
      {
        "en": "I gotta go now.",
        "hi": "मुझे अब जाना होगा।"
      }
    ],
    "notes": "Shows necessity in casual speech."
  },
  {
    "id": "mp17-4",
    "word": "lemme",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'let me'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A2",
    "examples": [
      {
        "en": "Lemme check my schedule.",
        "hi": "मुझे अपना शेड्यूल देखने दो।"
      }
    ],
    "notes": "Used when offering help or asking for permission casually."
  },
  {
    "id": "mp17-5",
    "word": "gimme",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'give me'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A2",
    "examples": [
      {
        "en": "Can you gimme a hand with this?",
        "hi": "क्या तुम इसमें मेरी मदद कर सकते हो?"
      }
    ],
    "notes": "Assimilation in fast speech."
  },
  {
    "id": "mp17-6",
    "word": "outta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'out of'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "Let's get outta here.",
        "hi": "चलो यहाँ से बाहर निकलते हैं।"
      }
    ],
    "notes": "Elision of the 'v' sound in 'of'."
  },
  {
    "id": "mp17-7",
    "word": "kinda",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'kind of'. Means 'somewhat' or 'rather'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "I'm kinda tired today.",
        "hi": "मैं आज थोड़ा थका हुआ हूँ।"
      }
    ],
    "notes": "Used as a filler or to soften a statement."
  },
  {
    "id": "mp17-8",
    "word": "sorta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'sort of'. Similar to 'kinda'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "It's sorta like a movie.",
        "hi": "यह एक तरह से फिल्म जैसा है।"
      }
    ],
    "notes": "Used to describe something loosely."
  },
  {
    "id": "mp17-9",
    "word": "lotta",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'a lot of'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A2",
    "examples": [
      {
        "en": "There are a lotta people here.",
        "hi": "यहाँ बहुत सारे लोग हैं।"
      }
    ],
    "notes": "The 't' often becomes a flap T sound."
  },
  {
    "id": "mp17-10",
    "word": "dunno",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'don't know' or 'do not know'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A2",
    "examples": [
      {
        "en": "I dunno what to do.",
        "hi": "मुझे नहीं पता कि क्या करना है।"
      }
    ],
    "notes": "Often accompanied by a shoulder shrug."
  },
  {
    "id": "mp17-11",
    "word": "c'mon",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'come on'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A2",
    "examples": [
      {
        "en": "C'mon, we're going to be late!",
        "hi": "जल्दी करो, हमें देर हो जाएगी!"
      }
    ],
    "notes": "Used to encourage someone or express frustration."
  },
  {
    "id": "mp17-12",
    "word": "cuz / 'cause",
    "partOfSpeech": "conjunction",
    "definition": "Informal spoken reduction of 'because'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "A1",
    "examples": [
      {
        "en": "I did it cuz I wanted to.",
        "hi": "मैंने यह इसलिए किया क्योंकि मैं चाहता था।"
      }
    ],
    "notes": "Elision of the first syllable."
  },
  {
    "id": "mp17-13",
    "word": "whatcha",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'what are you' or 'what do you'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "Whatcha doing tonight?",
        "hi": "आज रात तुम क्या कर रहे हो?"
      }
    ],
    "notes": "Assimilation: t + y = ch sound."
  },
  {
    "id": "mp17-14",
    "word": "gotcha",
    "partOfSpeech": "interjection",
    "definition": "Informal spoken reduction of 'I have got you'. Used to say 'I understand' or 'I caught you'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "Gotcha, I'll do it right away.",
        "hi": "समझ गया, मैं इसे तुरंत करूँगा।"
      }
    ],
    "notes": "Assimilation: t + y = ch sound."
  },
  {
    "id": "mp17-15",
    "word": "betcha",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'bet you'. Used to express confidence that something will happen.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B2",
    "examples": [
      {
        "en": "I betcha he forgets.",
        "hi": "मैं शर्त लगाता हूँ कि वह भूल जाएगा।"
      }
    ],
    "notes": "Assimilation: t + y = ch."
  },
  {
    "id": "mp17-16",
    "word": "doncha",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'don't you'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "Doncha wish it was Friday?",
        "hi": "क्या तुम नहीं चाहते कि आज शुक्रवार होता?"
      }
    ],
    "notes": "Assimilation: t + y = ch."
  },
  {
    "id": "mp17-17",
    "word": "didja",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'did you'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "Didja finish the report?",
        "hi": "क्या तुमने रिपोर्ट पूरी कर ली?"
      }
    ],
    "notes": "Assimilation: d + y = j sound (like 'judge')."
  },
  {
    "id": "mp17-18",
    "word": "wouldja",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'would you'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "Wouldja mind opening the window?",
        "hi": "क्या आप खिड़की खोल देंगे?"
      }
    ],
    "notes": "Assimilation: d + y = j sound."
  },
  {
    "id": "mp17-19",
    "word": "coulda",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'could have'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "I coulda helped you.",
        "hi": "मैं तुम्हारी मदद कर सकता था।"
      }
    ],
    "notes": "Elision of 'h' and 'v' in 'have'."
  },
  {
    "id": "mp17-20",
    "word": "shoulda",
    "partOfSpeech": "contraction",
    "definition": "Informal spoken reduction of 'should have'.",
    "usageContext": "informal, spoken",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "You shoulda told me earlier.",
        "hi": "तुम्हें मुझे पहले बताना चाहिए था।"
      }
    ],
    "notes": "Used for past regrets or advice."
  },
