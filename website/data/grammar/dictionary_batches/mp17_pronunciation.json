    "usageContext": "connected speech",
    "cefrLevel": "B1",
    "examples": [
      {
        "en": "I usta live there.",
        "hi": "मैं वहाँ रहता था।"
      }
    ],
    "notes": "The 'd' is completely dropped in connected speech."
  },
