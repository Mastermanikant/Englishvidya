---
layout: layouts/base.njk
---

{# Breadcrumb #}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol itemscope itemtype="https://schema.org/BreadcrumbList">
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/" itemprop="item"><span itemprop="name">Home</span></a>
      <meta itemprop="position" content="1">
    </li>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/grammar/" itemprop="item"><span itemprop="name">Grammar</span></a>
      <meta itemprop="position" content="2">
    </li>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <span itemprop="name">{{ title }}</span>
      <meta itemprop="position" content="3">
    </li>
  </ol>
</nav>

{# Article Schema #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title | jsonify | safe }},
  "description": {{ (description or title) | truncate(200) | jsonify | safe }},
  "url": "https://englishvidya.com/grammar/{{ slug }}/",
  "inLanguage": ["hi", "en"],
  "isPartOf": {
    "@type": "Course",
    "name": "English Grammar Course",
    "url": "https://englishvidya.com/grammar/"
  },
  "author": { "@type": "Organization", "name": "English Vidya" },
  "publisher": {
    "@type": "EducationalOrganization",
    "name": "English Vidya",
    "url": "https://englishvidya.com"
  },
  "educationalLevel": "Beginner",
  "about": { "@type": "Thing", "name": "English Grammar" }
}
</script>

{# Lesson Header #}
<div class="lesson-header animate-fade-in">
  {% if part %}
  <span class="badge">Lesson {{ part }}</span>
  {% endif %}
  <h1 style="margin-top: var(--sp-3);">{{ title | escHtml }}</h1>
</div>

{# Markdown Content #}
<div class="premium-card markdown-content" style="padding: var(--sp-6);">
  {{ content | safe }}

  {# Social Sharing Bar #}
  <div class="share-article-section">
    <div class="share-title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
      <span>इस पाठ को शेयर करें (Share this Lesson)</span>
    </div>
    <div class="share-buttons-grid">
      <a href="https://api.whatsapp.com/send?text={{ title | urlencode }}%20{{ site.siteUrl }}{{ page.url | urlencode }}" target="_blank" rel="noopener noreferrer" class="share-btn whatsapp" aria-label="WhatsApp पर शेयर करें">
        <svg viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.864-9.858.002-2.634-1.023-5.11-2.885-6.974C16.589 1.808 14.113.784 11.48.784c-5.442 0-9.866 4.42-9.87 9.858-.001 1.902.503 3.754 1.464 5.375L2.05 21.95l6.096-1.599c1.603.953 3.195 1.452 4.823 1.452v-.002zm12.012-7.147c-.244-.122-1.44-.71-1.662-.792-.222-.082-.384-.122-.545.123-.162.244-.627.792-.769.954-.143.162-.285.183-.529.061-.244-.122-1.03-.38-1.962-1.211-.725-.647-1.214-1.446-1.356-1.69-.143-.244-.015-.376.107-.497.11-.11.244-.285.366-.428.122-.143.163-.244.244-.408.082-.163.041-.306-.02-.428-.061-.122-.545-1.31-.747-1.797-.197-.475-.388-.411-.531-.418-.137-.007-.294-.008-.451-.008-.157 0-.413.059-.628.294-.216.236-.823.805-.823 1.963 0 1.157.842 2.277.96 2.433.117.156 1.657 2.53 4.015 3.545.561.242.997.387 1.339.496.562.178 1.074.153 1.479.092.45-.068 1.44-.588 1.642-1.157.202-.569.202-1.057.142-1.157-.061-.101-.223-.162-.467-.284z"/></svg>
        <span>WhatsApp</span>
      </a>
      <a href="https://www.facebook.com/sharer/sharer.php?u={{ site.siteUrl }}{{ page.url | urlencode }}" target="_blank" rel="noopener noreferrer" class="share-btn facebook" aria-label="Facebook पर शेयर करें">
        <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        <span>Facebook</span>
      </a>
      <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.siteUrl }}{{ page.url | urlencode }}" target="_blank" rel="noopener noreferrer" class="share-btn x-platform" aria-label="X (Twitter) पर शेयर करें">
        <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        <span>X</span>
      </a>
      <a href="https://www.threads.net/intent/post?text={{ title | urlencode }}%20{{ site.siteUrl }}{{ page.url | urlencode }}" target="_blank" rel="noopener noreferrer" class="share-btn threads" aria-label="Threads पर शेयर करें">
        <svg viewBox="0 0 24 24"><path d="M14.286 11.233c.12-.99-.074-1.785-.576-2.36-.502-.575-1.252-.865-2.247-.865-.95 0-1.686.276-2.207.828-.522.552-.777 1.312-.765 2.278.01.966.27 1.716.782 2.25.51.534 1.228.8 2.15.8.963 0 1.693-.277 2.19-.83.498-.553.719-1.245.663-2.076l1.244.085c.094 1.353-.263 2.502-1.07 3.447-.808.945-2.004 1.417-3.593 1.417-1.42 0-2.544-.424-3.37-1.272C6.012 16.037 5.6 14.822 5.6 13.24c0-1.685.424-2.98 1.272-3.886.848-.906 2.05-1.36 3.606-1.36 1.543 0 2.723.442 3.54 1.326.817.884 1.18 2.083 1.09 3.593l-1.246.085v.054zm7.314.81c.01 1.704-.265 3.25-.826 4.636-.56 1.386-1.378 2.558-2.453 3.513-1.075.956-2.378 1.674-3.908 2.155C12.883 22.828 11.168 23 9.273 23c-1.922 0-3.666-.233-5.232-.698a12.83 12.83 0 01-4.184-2.076 11.96 11.96 0 01-2.812-3.376C-3.8 15.512-4 13.916-4 12.062c0-1.897.233-3.626.7-5.187.466-1.562 1.18-2.923 2.143-4.084C-.194 1.63 1.096.91 2.607.428 4.118-.052 5.815-.292 7.7-.292c2.012 0 3.824.238 5.437.714A12.05 12.05 0 0117.26 2.52c1.157 1.127 2.008 2.518 2.55 4.174.544 1.656.782 3.498.715 5.526l-1.25-.042c.062-1.782-.14-3.398-.607-4.847-.466-1.448-1.18-2.658-2.142-3.63a10.82 10.82 0 00-3.655-2.22c-1.403-.418-2.983-.628-4.738-.628-1.684 0-3.197.21-4.54.63a10.8 10.8 0 00-3.565 1.83 10.74 10.74 0 00-2.463 2.943c-.63 1.185-.945 2.558-.945 4.12 0 1.637.318 3.036.953 4.195.635 1.16 1.488 2.077 2.558 2.753a11.63 11.63 0 003.774 1.677c1.396.353 2.985.53 4.768.53 1.685 0 3.208-.15 4.57-.45 1.36-.3 2.52-.77 3.475-1.41.956-.64 1.675-1.464 2.158-2.473.483-1.01.714-2.174.693-3.494l1.246.042z"/></svg>
        <span>Threads</span>
      </a>
      <a href="https://pinterest.com/pin/create/button/?url={{ site.siteUrl }}{{ page.url | urlencode }}&description={{ title | urlencode }}" target="_blank" rel="noopener noreferrer" class="share-btn pinterest" aria-label="Pinterest पर शेयर करें">
        <svg viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.41 7.61 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.966 1.406-5.966s-.359-.72-.359-1.781c0-1.663.967-2.906 2.17-2.906 1.024 0 1.517.768 1.517 1.686 0 1.029-.656 2.57-.996 3.996-.283 1.195.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.27 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.607 0 11.985-5.36 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/></svg>
        <span>Pinterest</span>
      </a>
      <button class="share-btn copy-link" onclick="copyLessonLink(this)" aria-label="लिंक कॉपी करें">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
        <span class="copy-text">Copy Link</span>
      </button>
      <button class="share-btn native-share" id="native-share-btn" style="display: none;" onclick="triggerNativeShare()" aria-label="अन्य माध्यम से शेयर करें">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
        <span>Share</span>
      </button>
    </div>
  </div>

  <script>
  function copyLessonLink(btn) {
    var url = window.location.href;
    navigator.clipboard.writeText(url).then(function() {
      var textSpan = btn.querySelector('.copy-text');
      var originalText = textSpan.textContent;
      textSpan.textContent = 'Copied!';
      btn.style.backgroundColor = '#14b8a6';
      btn.style.color = '#ffffff';
      btn.style.borderColor = '#14b8a6';
      
      setTimeout(function() {
        textSpan.textContent = originalText;
        btn.style.backgroundColor = '';
        btn.style.color = '';
        btn.style.borderColor = '';
      }, 2000);
    }).catch(function(err) {
      console.error('Failed to copy: ', err);
    });
  }

  function triggerNativeShare() {
    if (navigator.share) {
      navigator.share({
        title: '{{ title | escape }}',
        text: '{{ description or title | escape }}',
        url: window.location.href
      }).catch(function(err) {
        console.log('Share cancelled or failed: ', err);
      });
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    if (navigator.share) {
      var nativeBtn = document.getElementById('native-share-btn');
      if (nativeBtn) {
        nativeBtn.style.display = 'inline-flex';
      }
    }
  });
  </script>
</div>

{# Prev / Next Navigation using Eleventy Collections #}
{% set previousLesson = collections.grammar | getPreviousCollectionItem(page) %}
{% set nextLesson = collections.grammar | getNextCollectionItem(page) %}

<div class="lesson-nav-row" style="margin-top: var(--sp-6);">
  {% if previousLesson %}
  <a href="{{ previousLesson.url }}" class="lesson-nav-btn prev">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    <span>{{ previousLesson.data.title | truncate(30) }}</span>
  </a>
  {% else %}
  <div></div>
  {% endif %}

  {% if nextLesson %}
  <a href="{{ nextLesson.url }}" class="lesson-nav-btn next">
    <span>{{ nextLesson.data.title | truncate(30) }}</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </a>
  {% endif %}
</div>

<div style="text-align: center; margin-top: var(--sp-6); margin-bottom: var(--sp-8);">
  <a href="/grammar/" class="lesson-back-btn">← सभी Grammar Lessons देखें</a>
</div>
