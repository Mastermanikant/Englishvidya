{# ══ BREADCRUMBS PARTIAL ══
   Usage in any page frontmatter:
   breadcrumbs:
     - { label: "Home", url: "/" }
     - { label: "Grammar", url: "/grammar/" }
     - { label: "Topic 02: Language & Grammar" }  ← last item has no url
#}

{% if breadcrumbs and breadcrumbs.length > 1 %}
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs-list" itemscope itemtype="https://schema.org/BreadcrumbList">
    {% for crumb in breadcrumbs %}
    <li class="breadcrumbs-item"
        itemprop="itemListElement"
        itemscope
        itemtype="https://schema.org/ListItem">

      {% if crumb.url %}
        <a href="{{ crumb.url }}" class="breadcrumbs-link" itemprop="item">
          <span itemprop="name">{{ crumb.label }}</span>
        </a>
      {% else %}
        {# Last item — current page, no link #}
        <span class="breadcrumbs-current" itemprop="name" aria-current="page">
          {{ crumb.label }}
        </span>
      {% endif %}

      <meta itemprop="position" content="{{ loop.index }}" />

      {% if not loop.last %}
        <span class="breadcrumbs-sep" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      {% endif %}

    </li>
    {% endfor %}
  </ol>
</nav>
{% endif %}
