{# ══ HEADER PARTIAL — यहाँ बदलो, सभी pages पर बदलेगा ══ #}

{# ── TOP UTILITY BAR ── #}
<div class="top-utility-bar" id="top-utility-bar" role="banner">
  <div class="top-utility-inner">

    {# Left: Announcement #}
    <div class="utility-announcement">
      <span class="utility-dot" aria-hidden="true"></span>
      <span>🎓 Bihar Board Class 10 &amp; 12 content coming soon!</span>
    </div>

    {# Right: Contact + Social #}
    <div class="utility-links">
      <a href="mailto:{{ site.email }}" class="utility-link" aria-label="Email us">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span class="utility-link-text">{{ site.email }}</span>
      </a>

      <div class="utility-socials">
        <a href="{{ site.youtubeChannel | default('#') }}" target="_blank" rel="noopener noreferrer" class="utility-social-link" aria-label="YouTube Channel">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/></svg>
        </a>
        <a href="{{ site.whatsappChannel | default('#') }}" target="_blank" rel="noopener noreferrer" class="utility-social-link" aria-label="WhatsApp Channel">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-1.6-.8-2.7-1.4-3.7-3.2-.3-.5.3-.5.8-1.5.1-.2 0-.4-.1-.5-.1-.1-.7-1.7-.9-2.3-.3-.8-.5-.7-.7-.7h-.6c-.2 0-.5.1-.8.3-.3.3-1 1-1 2.4 0 1.4 1 2.7 1.1 2.9.1.2 2 3.1 4.9 4.3 1.8.8 2.5.8 3.4.7.5-.1 1.7-.7 1.9-1.3.2-.7.2-1.2.1-1.3z"/><path d="M12 2C6.5 2 2 6.5 2 12c0 1.9.5 3.7 1.4 5.3L2 22l4.7-1.4C8.3 21.5 10.1 22 12 22c5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18.3c-1.8 0-3.5-.5-5-1.4l-.3-.2-3.3 1 1-3.2-.2-.4C3.6 14.8 3.2 13.4 3.2 12c0-4.9 3.9-8.8 8.8-8.8 4.9 0 8.8 3.9 8.8 8.8 0 4.8-4 8.8-8.8 8.8z"/></svg>
        </a>
      </div>
    </div>

  </div>
</div>


{# Mobile Drawer Overlay #}
<div class="mobile-drawer-overlay" id="mobile-drawer-overlay" role="dialog" aria-label="Mobile Navigation Menu">
  <div class="mobile-drawer" id="mobile-drawer">
    <div class="mobile-drawer-header">
      <a href="/" class="logo" aria-label="{{ site.siteName }} Home">
        <img src="/assets/icons/logo.webp" alt="{{ site.siteName }}" class="logo-svg" width="36" height="36" loading="eager">
        <span class="logo-text"><span>English</span> <span class="logo-accent">Vidya</span></span>
      </a>
      <button class="mobile-drawer-close" id="mobile-drawer-close" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <nav class="mobile-drawer-nav" aria-label="Mobile Navigation Drawer">
      <button class="mobile-drawer-link pwa-drawer-install-btn" id="drawer-pwa-action" style="display:block; width:100%; text-align:left; background:transparent; border:none; color:var(--accent); font-weight:bold; cursor:pointer;">📱 Install App</button>
      <a href="/contact/" class="mobile-drawer-link" data-route="contact">✉️ Contact Us</a>
      <a href="/legal/" class="mobile-drawer-link" data-route="legal">📜 Policies</a>
      <a href="/settings/" class="mobile-drawer-link" data-route="settings">⚙️ Settings / Profile</a>

      <div class="social-icons-drawer" style="display:flex; justify-content:center; gap:var(--sp-4); margin-top:var(--sp-6);">
        <a href="{{ site.whatsappChannel | default('#') }}" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        </a>
        <a href="{{ site.facebookPage | default('#') }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="{{ site.instagramPage | default('#') }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="{{ site.youtubeChannel | default('#') }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
        </a>
        <a href="{{ site.twitterPage | default('#') }}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z" /><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772" /></svg>
        </a>
      </div>
    </nav>
  </div>
</div>

{# Sticky Glass Header #}
<header class="app-header" id="app-header">
  <div class="header-left">
    <button class="header-btn mobile-menu-trigger" id="mobile-menu-trigger"
      aria-label="Menu" aria-expanded="false" style="margin-right: var(--sp-3);">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="6" x2="20" y2="6"></line>
        <line x1="4" y1="18" x2="20" y2="18"></line>
      </svg>
    </button>
    <a href="/" class="logo" id="logo-link" aria-label="{{ site.siteName }} Home">
      <img src="/assets/icons/logo.webp" alt="{{ site.siteName }}" class="logo-svg" width="36" height="36" loading="eager">
      <span class="logo-text"><span>English</span> <span class="logo-accent">Vidya</span></span>
    </a>

  </div>

  {# Desktop Navigation #}
  <nav class="desktop-nav" aria-label="Desktop Navigation" id="desktop-nav">
    {% for item in site.nav %}
    <a href="{{ item.href }}" class="desktop-nav-link{% if page.url == item.href %} active{% endif %}" data-route="{{ item.route }}">
      {{ item.label }}
    </a>
    {% endfor %}
  </nav>

  <div class="header-right">
    <button class="header-btn" id="search-trigger-btn" aria-label="Search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
    </button>
    <button class="header-btn" id="theme-toggle-btn" aria-label="Toggle Theme">
      <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</header>
