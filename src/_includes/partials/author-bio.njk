{# ══ AUTHOR BIO CARD ══ #}
<style>
.author-bio-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    padding: 20px;
    margin-top: 40px;
    margin-bottom: 20px;
}
.author-avatar {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #38bdf8;
}
.author-info h3 {
    margin: 0 0 5px 0;
    font-size: 1.2rem;
    color: #f8fafc;
}
.author-info p {
    margin: 0 0 10px 0;
    font-size: 0.95rem;
    color: #cbd5e1;
    line-height: 1.4;
}
.author-socials {
    display: flex;
    gap: 12px;
}
.author-socials a {
    color: #94a3b8;
    transition: color 0.3s;
}
.author-socials a:hover {
    color: #38bdf8;
}
.author-socials svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
}
@media (max-width: 600px) {
    .author-bio-card {
        flex-direction: column;
        text-align: center;
    }
}
</style>

<div class="author-bio-card">
    <img src="/assets/images/my-pic.png" alt="Master Manikant" class="author-avatar" onerror="this.src='/assets/icons/logo.webp'">
