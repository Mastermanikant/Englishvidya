permalink: /grammar/
---

{#
  GRAMMAR LIST PAGE
  URL: englishvidya.com/grammar/
  SEO: Real HTML list of all lessons — Google index kar sakta hai
#}

{# Breadcrumb #}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Home</a></li>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <li>Grammar</li>
  </ol>
</nav>

<div class="hero-welcome animate-fade-in" style="padding-bottom: var(--sp-4);">
  <h1 style="font-size: 1.5rem;">📖 Grammar Lessons</h1>
  <p class="hero-subtitle">हिंदी माध्यम के छात्रों के लिए — सरल भाषा में समझाया गया</p>
</div>

{# Schema.org Course structured data for SEO #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "English Grammar Course",
  "description": "हिंदी माध्यम के छात्रों के लिए 60+ Grammar Topics — Tenses, Articles, Nouns और बहुत कुछ।",
  "provider": {
    "@type": "EducationalOrganization",
    "name": "English Vidya",
    "url": "https://englishvidya.com"
  },
  "hasCourseInstance": [
    {% for lesson in lessonPages %}
    {
      "@type": "CourseInstance",
      "name": "{{ lesson.title | escHtml }}",
      "url": "https://englishvidya.com/grammar/{{ lesson.slug }}/"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

{# Lesson List — Real HTML for SEO #}
<div class="chapter-list" role="list">
  {% for lesson in lessonPages | sort(false, false, 'part') %}
  <a href="/grammar/{{ lesson.slug }}/" class="chapter-item" role="listitem"
     aria-label="Lesson {{ lesson.part }}: {{ lesson.title }}">
    <div class="chapter-num">{{ lesson.part }}</div>
    <div class="chapter-info">
      <div class="chapter-title">{{ lesson.title | escHtml }}</div>
    </div>
    <span class="chapter-arrow" aria-hidden="true">→</span>
  </a>
  {% else %}
  <div class="card" style="text-align:center; padding: var(--sp-10);">
    <p style="font-size: 2rem;">🚧</p>
    <h2>Lessons coming soon!</h2>
  </div>
  {% endfor %}
</div>
