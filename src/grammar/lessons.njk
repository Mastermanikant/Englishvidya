---
layout: layouts/base.njk
pagination:
  data: lessonPages
  size: 1
  alias: lesson
permalink: "/grammar/{{ lesson.slug }}/"
---

{#
  GRAMMAR LESSON PAGE — Auto-generated from JSON
  URL: englishvidya.com/grammar/{{ lesson.slug }}/
  Content is real HTML — SEO bots can read it directly!
#}

{# Breadcrumb #}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol itemscope itemtype="https://schema.org/BreadcrumbList">
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/" itemprop="item"><span itemprop="name">Home</span></a>
      <meta itemprop="position" content="1">
    </li>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/grammar/" itemprop="item"><span itemprop="name">Grammar</span></a>
      <meta itemprop="position" content="2">
    </li>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <span itemprop="name">{{ lesson.title }}</span>
      <meta itemprop="position" content="3">
    </li>
  </ol>
</nav>

{# Article Schema — SEO + AEO (Google & GPT dono ke liye) #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ lesson.title | jsonify | safe }},
  "description": {{ (lesson.definition_en or lesson.title) | truncate(200) | jsonify | safe }},
  "url": "https://englishvidya.com/grammar/{{ lesson.slug }}/",
  "inLanguage": ["hi", "en"],
  "isPartOf": {
    "@type": "Course",
    "name": "English Grammar Course",
    "url": "https://englishvidya.com/grammar/"
  },
  "author": { "@type": "Organization", "name": "English Vidya" },
  "publisher": {
    "@type": "EducationalOrganization",
    "name": "English Vidya",
    "url": "https://englishvidya.com"
  },
  "educationalLevel": "Beginner",
  "about": { "@type": "Thing", "name": "English Grammar" }
}
</script>

{# Lesson Header #}
<div class="lesson-header animate-fade-in">
  <span class="badge">Lesson {{ lesson.part }}</span>
  <h1 style="margin-top: var(--sp-3);">{{ lesson.title | escHtml }}</h1>
</div>

{# Teacher Note #}
{% if lesson.teacher_note %}
<div class="card teacher-card">
  <div class="teacher-header">
    <div class="teacher-avatar">👨‍🏫</div>
    <div>
      <div class="teacher-name">Teacher's Note</div>
      <div class="teacher-role">English Mentor</div>
    </div>
  </div>
  <div class="teacher-quote">"{{ lesson.teacher_note | escHtml }}"</div>
</div>
{% endif %}

{# Definition Card #}
{% if lesson.definition_en %}
<div class="card">
  <h2>Definition</h2>
  <p style="margin-top: var(--sp-3); font-size: 1.05rem; font-weight: 500;">
    {{ lesson.definition_en | escHtml }}
  </p>
  {% if lesson.definition_hi %}
  <div class="definition-block" style="margin-top: var(--sp-3);">
    <strong>Hindi (हिंदी):</strong> {{ lesson.definition_hi | escHtml }}
  </div>
  {% endif %}
</div>
{% endif %}

{# Categories / Examples — HTML <details> = shrink/expand #}
{% if lesson.categories and lesson.categories.length %}
<div class="examples-accordion">
  {% for cat in lesson.categories %}
  <details class="accordion-item" {% if loop.first %}open{% endif %}>
    <summary class="accordion-trigger">
      <span>{{ cat.name | escHtml }}</span>
      <span class="accordion-arrow" aria-hidden="true">›</span>
    </summary>
    <div class="accordion-content">
      <div class="accordion-body">
        {% if cat.intro %}
        <p class="accordion-intro">{{ cat.intro | escHtml | nl2br | safe }}</p>
        {% endif %}
        {% for ex in cat.examples %}
        <div class="example-pair">
          <div class="example-en">{{ ex.en | escHtml }}</div>
          <div class="example-hi">{{ ex.hi | escHtml }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </details>
  {% endfor %}
</div>
{% endif %}

{# Prev / Next Navigation #}
{% set lessonIdx = -1 %}
{% for l in allLessons %}
  {% if l.slug == lesson.slug %}{% set lessonIdx = loop.index0 %}{% endif %}
{% endfor %}

<div class="lesson-nav-row">
  {% if lessonIdx > 0 %}
  {% set prevL = allLessons[lessonIdx - 1] %}
  <a href="/grammar/{{ prevL.slug }}/" class="lesson-nav-btn prev">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    <span>{{ prevL.title | truncate(30) }}</span>
  </a>
  {% endif %}

  {% if lessonIdx >= 0 and lessonIdx < (allLessons | length - 1) %}
  {% set nextL = allLessons[lessonIdx + 1] %}
  <a href="/grammar/{{ nextL.slug }}/" class="lesson-nav-btn next">
    <span>{{ nextL.title | truncate(30) }}</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </a>
  {% endif %}
</div>

<div style="text-align: center; margin-top: var(--sp-6); margin-bottom: var(--sp-8);">
  <a href="/grammar/" class="lesson-back-btn">← सभी Grammar Lessons देखें</a>
</div>
