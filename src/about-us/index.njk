    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // State
    let currentSection = 'platform';
    let currentLang = 'en';

    const tabBtns = document.querySelectorAll('.tab-btn');
    const langBtns = document.querySelectorAll('.lang-btn');
    const sections = {
        platform: document.getElementById('section-platform'),
        founder: document.getElementById('section-founder')
    };

    function updateUI() {
        // Update Section Tabs
        tabBtns.forEach(btn => {
            if (btn.dataset.target === currentSection) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // Update Lang Tabs
        langBtns.forEach(btn => {
            if (btn.dataset.lang === currentLang) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // Show/Hide Sections
        Object.keys(sections).forEach(key => {
            if (key === currentSection) {
                sections[key].classList.add('active');
                // Within active section, update language display
                const enContent = sections[key].querySelector('.lang-en');
                const hiContent = sections[key].querySelector('.lang-hi');
                if (enContent) enContent.style.display = currentLang === 'en' ? 'block' : 'none';
                if (hiContent) hiContent.style.display = currentLang === 'hi' ? 'block' : 'none';
            } else {
                sections[key].classList.remove('active');
            }
        });
    }

    // Event Listeners
    tabBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            currentSection = e.target.dataset.target;
            updateUI();
        });
    });

    langBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            currentLang = e.target.dataset.lang;
            updateUI();
        });
    });

    // Initial render
    updateUI();
});
</script>
