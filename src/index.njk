{# ═══ 3. RECENT LESSONS — Real links, SEO perfect #}
<section class="animate-in d-6" aria-labelledby="lessons-heading">
  <div class="section-header-wrap">
    <p class="section-label" id="lessons-heading">📚 Grammar Lessons</p>
    <a href="/grammar/" class="see-all-link">सभी देखें →</a>
  </div>
  <div class="chapter-list">
    {% for lesson in lessonPages | sort(false, false, "part") | slice(0, 5) %}
    <a href="/grammar/{{ lesson.slug }}/" class="chapter-item">
      <div class="chapter-num">{{ lesson.part }}</div>
      <div class="chapter-info">
        <div class="chapter-title">{{ lesson.title | escHtml }}</div>
      </div>
      <span class="chapter-arrow" aria-hidden="true">→</span>
    </a>
    {% endfor %}
  </div>
</section>

