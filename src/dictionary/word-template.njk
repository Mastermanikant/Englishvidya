---
layout: layouts/base.njk
pagination:
  data: allWords
  size: 1
  alias: wordData
permalink: "/dictionary/{{ wordData.slug }}/index.html"
---

{#
  DICTIONARY WORD PAGE (Auto-generated Programmatic SEO)
  URL: /dictionary/{{ wordData.slug }}/
#}

<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol itemscope itemtype="https://schema.org/BreadcrumbList">
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/" itemprop="item"><span itemprop="name">Home</span></a>
      <meta itemprop="position" content="1">
    </li>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/dictionary/" itemprop="item"><span itemprop="name">Dictionary</span></a>
      <meta itemprop="position" content="2">
    </li>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <span itemprop="name">{{ wordData.word }}</span>
      <meta itemprop="position" content="3">
    </li>
  </ol>
</nav>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": "{{ wordData.word | escHtml }}",
  "description": "{{ wordData.meaning | escHtml }}",
  "inDefinedTermSet": "https://englishvidya.com/dictionary/"
}
</script>

<div class="card animate-fade-in" style="margin-top: var(--sp-6); text-align: center; padding: var(--sp-8) var(--sp-4);">
  <h1 style="font-size: 2.5rem; color: var(--text-primary); margin-bottom: var(--sp-2);">{{ wordData.word | escHtml }}</h1>
  
  {% if wordData.pron %}
  <div style="font-size: 1.2rem; color: var(--accent); margin-bottom: var(--sp-4);">
    {{ wordData.pron | escHtml }}
  </div>
  {% endif %}
  
  <div style="font-size: 1.5rem; font-weight: bold; margin-bottom: var(--sp-6);">
    {{ wordData.meaning | escHtml }}
  </div>
  
  {% if wordData.example %}
  <div style="background: var(--bg-body); padding: var(--sp-4); border-radius: var(--radius-md); font-style: italic; margin-bottom: var(--sp-6);">
    "{{ wordData.example | escHtml }}"
  </div>
  {% endif %}
  
  <button class="btn btn-primary" onclick="speakWord('{{ wordData.word | escHtml }}')" style="display: inline-flex; align-items: center; gap: 8px;">
    🔊 Listen Pronunciation
  </button>
</div>

<div style="text-align: center; margin-top: var(--sp-8);">
  <a href="/dictionary/?cat={{ wordData.category }}" class="lesson-back-btn">← Back to Category</a>
</div>
