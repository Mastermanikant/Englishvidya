---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  {# ── Static / Priority Pages ── #}
  <url>
    <loc>https://englishvidya.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>https://englishvidya.com/grammar/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://englishvidya.com/dictionary/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://englishvidya.com/flashcards/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>

  <url>
    <loc>https://englishvidya.com/about-us/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <url>
    <loc>https://englishvidya.com/contact/</loc>
    <changefreq>yearly</changefreq>
    <priority>0.5</priority>
  </url>

  <url>
    <loc>https://englishvidya.com/legal/</loc>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>

  {# ── Grammar Topics — auto-generate from collections ── #}
  {% for post in collections.all %}
    {% if post.url and post.url != "/" and post.data.eleventyExcludeFromCollections != true %}
      {% if "/grammar/" in post.url and post.url != "/grammar/" %}
  <url>
    <loc>https://englishvidya.com{{ post.url }}</loc>
    <lastmod>{% if post.date %}{{ post.date | toISO }}{% else %}2026-01-01{% endif %}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
      {% endif %}
    {% endif %}
  {% endfor %}

  {# ── Dictionary Words — auto-generate ── #}
  {% for post in collections.all %}
    {% if post.url and post.data.eleventyExcludeFromCollections != true %}
      {% if "/dictionary/" in post.url and post.url != "/dictionary/" %}
  <url>
    <loc>https://englishvidya.com{{ post.url }}</loc>
    <lastmod>{% if post.date %}{{ post.date | toISO }}{% else %}2026-01-01{% endif %}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
      {% endif %}
    {% endif %}
  {% endfor %}

</urlset>
