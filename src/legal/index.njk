<script>
// Tab switching for legal page
(function () {
  var tabs = document.querySelectorAll('.legal-tab');
  var panes = document.querySelectorAll('.legal-pane');
  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      tabs.forEach(function (t) { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
      panes.forEach(function (p) { p.hidden = true; });
      tab.classList.add('active');
      tab.setAttribute('aria-selected','true');
      var target = document.getElementById('pane-' + tab.dataset.tab);
      if (target) target.hidden = false;
    });
  });
})();
</script>
